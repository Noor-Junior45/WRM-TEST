rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isDocOwner() {
      return (request.auth != null && resource != null && resource.data.userId == request.auth.uid) ||
             (request.auth == null && resource != null && resource.data.userId != null);
    }

    function isNewDocOwner() {
      return (request.auth != null && request.resource != null && request.resource.data.userId == request.auth.uid) ||
             (request.auth == null && request.resource != null && request.resource.data.userId != null);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Products collection
    match /products/{productId} {
      allow read, delete: if isDocOwner();
      allow create: if isNewDocOwner() && isValidId(productId);
      allow update: if isDocOwner() && isNewDocOwner();
    }

    // Customers collection
    match /customers/{customerId} {
      allow read, delete: if isDocOwner();
      allow create: if isNewDocOwner() && isValidId(customerId);
      allow update: if isDocOwner() && isNewDocOwner();
    }

    // Sales collection
    match /sales/{saleId} {
      allow read, delete: if isDocOwner();
      allow create: if isNewDocOwner() && isValidId(saleId);
      allow update: if isDocOwner() && isNewDocOwner();
    }

    // Tags collection
    match /tags/{tagId} {
      allow read, delete: if isDocOwner();
      allow create: if isNewDocOwner() && isValidId(tagId);
      allow update: if isDocOwner() && isNewDocOwner();
    }

    // Settings collection
    match /settings/{settingsId} {
      allow read, delete: if isDocOwner();
      allow create: if isNewDocOwner() && isValidId(settingsId);
      allow update: if isDocOwner() && isNewDocOwner();
    }

    // Deleted items collection
    match /deletedItems/{deletedItemId} {
      allow read, delete: if isDocOwner();
      allow create: if isNewDocOwner() && isValidId(deletedItemId);
      allow update: if isDocOwner() && isNewDocOwner();
    }

    // Staff collection
    match /staff/{staffId} {
      allow read, write: if (request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.resource == null || request.resource.data.userId == request.auth.uid)) ||
                            (request.auth == null);
    }

    // Product history collection
    match /productHistory/{historyId} {
      allow read, write: if (request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.resource == null || request.resource.data.userId == request.auth.uid)) ||
                            (request.auth == null);
    }
  }
}
